{
  "manifest_version": 3,
  "name": "YT Downloader",
  "version": "1.0",
  "description": "Lisää nykyisen sivun latausjonoon.",
  "permissions": ["activeTab"],
  "background": {
    "scripts": ["background.js"]
  },
  "icons": {
    "48": "yt_logo_icon.png",
    "96": "yt_logo_icon.png"
  },
  "action": {
    "default_title": "Lataa tämä video",
    "default_icon": "yt_logo_icon.png"
  }
}